
// Variável para armazenar a quantidade de itens no carrinho
let itensNoCarrinho = 0;

// Função para simular a adição de um produto ao carrinho
function adicionarAoCarrinho(nomeProduto) {
    itensNoCarrinho++;
    
    // Atualiza o número no botão do carrinho no HTML
    document.getElementById('contador-carrinho').innerText = itensNoCarrinho;
    
    // Exibe um feedback para o usuário
    alert(`${nomeProduto} foi adicionado ao seu carrinho!`);
}

// Evento interativo extra: Clique no botão do carrinho principal
document.getElementById('btn-carrinho').addEventListener('click', function() {
    if (itensNoCarrinho === 0) {
        alert("Seu carrinho está vazio. Adicione alguns produtos!");
    } else {
        alert(`Você tem ${itensNoCarrinho} item(ns) no carrinho. Pronto para finalizar a compra?`);
    }
});
