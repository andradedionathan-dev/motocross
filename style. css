/* Reset básico de estilos */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

body {
    background-color: #121212;
    color: #ffffff;
    scroll-behavior: smooth;
}

/* Cabeçalho */
header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 8%;
    background-color: #1a1a1a;
    border-bottom: 3px solid #ff5500;
    position: sticky;
    top: 0;
    z-index: 1000;
}

.logo {
    font-size: 24px;
    font-weight: bold;
    text-transform: uppercase;
}

.logo span {
    color: #ff5500;
}

nav ul {
    display: flex;
    list-style: none;
}

nav ul li {
    margin: 0 15px;
}

nav ul li a {
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    transition: color 0.3s;
}

nav ul li a:hover {
    color: #ff5500;
}

.cart-icon {
    font-size: 20px;
    cursor: pointer;
    background: #2a2a2a;
    padding: 8px 15px;
    border-radius: 20px;
}

/* Banner Principal */
.hero {
    height: 70vh;
    background: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.8)), url('https://images.unsplash.com/photo-1558981806-ec527fa84c39?q=80&w=1470') no-repeat center center/cover;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 20px;
}

.hero-content h1 {
    font-size: 48px;
    margin-bottom: 15px;
    text-transform: uppercase;
}

.hero-content p {
    font-size: 18px;
    margin-bottom: 25px;
    color: #ccc;
}

.btn {
    display: inline-block;
    padding: 12px 30px;
    background-color: #ff5500;
    color: #fff;
    text-decoration: none;
    font-weight: bold;
    border-radius: 5px;
    transition: background 0.3s;
}

.btn:hover {
    background-color: #e04a00;
}

/* Seção de Produtos */
.products-section {
    padding: 60px 8%;
}

.products-section h2 {
    text-align: center;
    margin-bottom: 40px;
    font-size: 32px;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
}

.product-card {
    background-color: #1a1a1a;
    padding: 25px;
    border-radius: 8px;
    text-align: center;
    border: 1px solid #2a2a2a;
    transition: transform 0.3s, border-color 0.3s;
    position: relative;
}

.product-card:hover {
    transform: translateY(-5px);
    border-color: #ff5500;
}

.badge {
    position: absolute;
    top: 15px;
    left: 15px;
    background-color: #ff5500;
    font-size: 12px;
    padding: 3px 8px;
    font-weight: bold;
    border-radius: 3px;
}

.product-card h3 {
    margin: 20px 0 10px 0;
    font-size: 20px;
}

.product-card p {
    font-size: 14px;
    color: #aaa;
    margin-bottom: 20px;
    line-height: 1.5;
}

.buy-btn {
    width: 100%;
    padding: 10px;
    background-color: transparent;
    color: #ff5500;
    border: 2px solid #ff5500;
    font-weight: bold;
    cursor: pointer;
    border-radius: 5px;
    transition: all 0.3s;
}

.buy-btn:hover {
    background-color: #ff5500;
    color: #fff;
}

/* Rodapé */
footer {
    text-align: center;
    padding: 30px;
    background-color: #0d0d0d;
    color: #666;
    font-size: 14px;
    margin-top: 40px;
}
